Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"vectorfield", "[", 
   RowBox[{"x", ",", "y"}], "]"}], "/.", 
  RowBox[{"b", "->", "bbk"}]}]], "Input",
 CellChangeTimes->{{3.982855511950412*^9, 3.982855512892351*^9}},
 CellLabel->
  "In[798]:=",ExpressionUUID->"fd66b8ff-4413-493f-b183-5a82fb6ef719"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"-", "0.01`"}], " ", "x"}], "+", "y"}], ",", 
   RowBox[{
    RowBox[{"-", "x"}], "-", 
    RowBox[{"0.01`", " ", "y"}], "-", 
    RowBox[{
     SuperscriptBox["x", "2"], " ", "y"}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.982855489888585*^9, 3.98285551337683*^9}},
 CellLabel->
  "Out[798]=",ExpressionUUID->"e5756d2e-f565-49cf-8d4e-5fd753d3a00f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"For", " ", "supercritical"}], ",", 
    RowBox[{
    "use", " ", "forward_eq", "\n", "   ", "For", " ", "subcritical"}], ",", 
    RowBox[{"use", " ", "backward_eq"}]}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"vectorfield", "[", 
      RowBox[{"x_", ",", "y_"}], "]"}], "=", 
     RowBox[{"forwards", "[", 
      RowBox[{"x", ",", "y"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"vectorfield_eq", "=", "backward_eq"}], " ", "*)"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"fixed", " ", "point", " ", "location", " ", 
     RowBox[{"doesn", "'"}], "t", " ", "depend", " ", "on", " ", "b", " ", 
     "for", " ", "this", " ", "portrait"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fpstable", " ", "=", " ", 
     RowBox[{"Graphics", "[", 
      RowBox[{"Disk", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", "0.1"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fpunstable", " ", "=", " ", 
     RowBox[{"Graphics", "[", 
      RowBox[{"Circle", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", "0.1"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"p1a", " ", "=", " ", 
     RowBox[{"StreamPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"vectorfield", "[", 
         RowBox[{"x", ",", "y"}], "]"}], "/.", 
        RowBox[{"b", "->", "bbk"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
       RowBox[{"StreamPoints", "->", "20"}], ",", 
       RowBox[{"Frame", "->", "None"}], ",", 
       RowBox[{"Axes", "->", "True"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}]}], ",", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"{", 
         RowBox[{"200", ",", "200"}], "}"}]}], ",", 
       RowBox[{"StreamScale", "\[Rule]", "Large"}], ",", 
       RowBox[{"StreamStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", "\"\<Line\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"StringForm", "[", 
         RowBox[{"\"\<b = ``. stable fp in fwd time\>\"", ",", "bbk"}], 
         "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p1b", "=", 
     RowBox[{
      RowBox[{"Normal", "[", "p1a", "]"}], "/.", " ", 
      RowBox[{
       RowBox[{"Line", "[", "x_", "]"}], ":>", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Arrowheads", "[", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"0.06", ",", "0.5"}], "}"}], "}"}], "]"}], ",", 
         RowBox[{"Arrow", "[", "x", "]"}]}], "}"}]}]}]}], ";"}], "\n", 
   RowBox[{"p1", " ", "=", " ", 
    RowBox[{"Show", "[", 
     RowBox[{"p1b", ",", "fpstable"}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2a", " ", "=", " ", 
     RowBox[{"StreamPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"vectorfield", "[", 
         RowBox[{"x", ",", "y"}], "]"}], "/.", 
        RowBox[{"b", "->", "bfwd"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
       RowBox[{"StreamPoints", "->", "20"}], ",", 
       RowBox[{"Frame", "->", "None"}], ",", 
       RowBox[{"Axes", "->", "True"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}]}], ",", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"{", 
         RowBox[{"200", ",", "200"}], "}"}]}], ",", 
       RowBox[{"StreamScale", "\[Rule]", "Large"}], ",", 
       RowBox[{"StreamStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", "\"\<Line\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"StringForm", "[", 
         RowBox[{"\"\<b = ``. unstable fp in fwd time\>\"", ",", "bfwd"}], 
         "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2b", "=", 
     RowBox[{
      RowBox[{"Normal", "[", "p2a", "]"}], "/.", " ", 
      RowBox[{
       RowBox[{"Line", "[", "x_", "]"}], ":>", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Arrowheads", "[", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"0.06", ",", "0.5"}], "}"}], "}"}], "]"}], ",", 
         RowBox[{"Arrow", "[", "x", "]"}]}], "}"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"p2", " ", "=", " ", 
    RowBox[{"Show", "[", 
     RowBox[{"p2b", ",", "fpunstable"}], "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9828553497766247`*^9, 3.982855552382574*^9}, {
