Cell["\<\
From the Poincar\[EAcute] map, I see that there is a limit cycle.  The slope \
of the map curve is positive, and less than 1, at the fixed point so this is \
a stable limit cycle.\
\>", "Item",
 CellChangeTimes->{{3.888582407340979*^9, 3.888582432378068*^9}, {
  3.9829278009444532`*^9, 
  3.9829278011970987`*^9}},ExpressionUUID->"a73f77bc-ed57-4519-bf22-\
58405a29f04f"],

Cell[CellGroupData[{

Cell["\<\
It would be nice to check that the limit cycle size scales reasonably (radius \
should grow as sqrt(m))\
\>", "Subsubsection",
 CellChangeTimes->{{3.982927785343207*^9, 
  3.982927785656807*^9}},ExpressionUUID->"7b8aa4b9-29b4-414c-9be7-\
d6e408c275b8"],

Cell["\<\
If our Hopf appears to be subcritical then do this using the backwards time \
system (so that the limit cycle is stabilized).  If supercritical then use \
the forward time system.  We will not do that work here.\
\>", "Item",
 CellChangeTimes->{{3.8885824658572607`*^9, 3.8885824748887243`*^9}, 
   3.982927792532233*^9},ExpressionUUID->"aa0655ca-c22c-484d-a8c1-\
676f8b0b3643"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Extra Example: Restrict the domain in solve for an angular variable\
\>", "Section",
 CellChangeTimes->{{3.888504119956897*^9, 3.888504121216907*^9}, {
  3.8885824767170258`*^9, 
  3.8885824774691687`*^9}},ExpressionUUID->"acab19ec-bff3-4591-a867-\
976a4244d90d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fp", " ", "=", " ", 
     RowBox[{"Solve", "[", 
      RowBox[{"{", 
       RowBox[{"Cos", "[", 
        RowBox[{"x", "]", "==", 
         RowBox[{"0", ",", 
          RowBox[{"0", "\[LessEqual]", " ", 
           RowBox[{"x", ",", 
            RowBox[{"x", "<", 
             RowBox[{"2", "Pi"}]}]}]}]}]}]}]}]}]}], "}"}], ",", "x"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.982856212793453*^9, 
  3.982856213794693*^9}},ExpressionUUID->"8eda7b84-9658-4303-99a2-\
7b326cf32c16"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     FractionBox["\[Pi]", "2"]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     FractionBox[
      RowBox[{"3", " ", "\[Pi]"}], "2"]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.982856205374422*^9},
 CellLabel->
  "Out[911]=",ExpressionUUID->"8c217a1f-b067-4497-99ac-5af2a9743637"]
}, Open  ]]
}, Open  ]]
},
