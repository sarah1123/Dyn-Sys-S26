Cell[CellGroupData[{

Cell["\<\
Attempt to classify a Hopf bifurcation using phase portraits and trajectories\
\
\>", "Section",
 CellChangeTimes->{{3.8885042942432947`*^9, 
  3.8885043052541943`*^9}},ExpressionUUID->"73ee06b0-1445-4dc5-9d5d-\
d3cc573d24ae"],

Cell["\<\
The Hopf bifurcation in the example above occurs at (0, 0) when \[Mu] = 0 \
(trace = 0 and det > 0) \
\>", "Text",
 CellChangeTimes->{{3.8885043420944557`*^9, 3.888504354214511*^9}, {
  3.8885820497817507`*^9, 
  3.8885820524042377`*^9}},ExpressionUUID->"1640df5e-18f1-4592-8191-\
92cf11c8e87c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"fp", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "0"}], ",", 
     RowBox[{"y", "\[Rule]", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"determ", " ", "=", " ", 
  RowBox[{
   RowBox[{"Det", "[", "jacobian", "]"}], "/.", "fp"}]}], "\n", 
 RowBox[{"trace", " ", "=", " ", 
  RowBox[{
   RowBox[{"Tr", "[", "jacobian", "]"}], "/.", "fp"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"0", ",", "0"}], ")"}], " ", "is", " ", "stable", " ", "for", 
     " ", "\[Mu]"}], "<", 
    RowBox[{"0", " ", "and", " ", "unstable", " ", "for", " ", "\[Mu]"}], ">",
     "0"}], " ", "*)"}]}]}], "Input",
 CellChangeTimes->{
  3.888504310153347*^9, {3.888504356717575*^9, 3.888504372529248*^9}},
 CellLabel->
  "In[387]:=",ExpressionUUID->"892c6c49-f574-4169-bab2-fd0439396988"],

Cell[BoxData[
 RowBox[{"1", "+", 
  SuperscriptBox["b", "2"]}]], "Output",
 CellChangeTimes->{{3.8885043578021097`*^9, 3.8885043730668497`*^9}, 
   3.88858219274734*^9, 3.9828535505420113`*^9, 3.9828540205989103`*^9},
 CellLabel->
  "Out[388]=",ExpressionUUID->"58cfb54d-454d-4e18-ada1-a451f4c76b9f"],

Cell[BoxData[
 RowBox[{"2", " ", "b"}]], "Output",
 CellChangeTimes->{{3.8885043578021097`*^9, 3.8885043730668497`*^9}, 
   3.88858219274734*^9, 3.9828535505420113`*^9, 3.982854020600638*^9},
 CellLabel->
  "Out[389]=",ExpressionUUID->"3b419bca-6077-40f8-a222-643f7544b898"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Is the bifurcation subcritical or supercritical?", "Subsection",
 CellChangeTimes->{{3.8885043892536993`*^9, 3.8885044476805353`*^9}, 
   3.982853582111228*^9},ExpressionUUID->"cee3cae4-6831-4893-bcb7-\
832f245c5018"],

Cell[TextData[{
 "If the bifurcation is ",
 StyleBox["subcritical",
  FontWeight->"Bold"],
 ", an ",
 StyleBox["unstable",
  FontWeight->"Bold"],
 " limit cycle is born at the bifurcation point around the stable fixed \
point.\nNo new limit cycle is created around the unstable fixed point.\n\nIf \
the bifurcation is ",
 StyleBox["supercritical",
  FontWeight->"Bold"],
 ", a ",
 StyleBox["stable",
  FontWeight->"Bold"],
 " limit cycle is born at the bifurcation point around the unstable fixed \
point.\nNo new limit cycle is created around the stable fixed point.\n\nWe \
will create trajectories to look for these limit cycles.\n\n- Stay ",
 StyleBox["close",
  FontWeight->"Bold"],
 " to the bifurcation value so that the new limit cycle remains small.\n- Use \
initial conditions ",
 StyleBox["close",
  FontWeight->"Bold"],
 " to the fixed point.\n- Use ",
 StyleBox["backward",
  FontWeight->"Bold"],
 " time integration on the side with the stable fixed point so that an \
unstable limit cycle would be stabilized.\n- Use ",
 StyleBox["forward",
  FontWeight->"Bold"],
 " time integration on the side with the unstable fixed point so that a \
stable limit cycle would be stable.\n\n\nYou should observe:\n- One of the \
trajectories saturates at a small limit cycle (that is the side with the new \
limit cycle)\n- The other trajectory may saturate at a larger limit cycle or \
may escape to infinity.\n\nThere may be other limit cycles in the system. Our \
goal is to isolate the ",
 StyleBox["newly created cycle",
  FontWeight->"Bold"],
 ", whose radius approaches zero at the bifurcation point. For this reason, \
keep both the parameter value and the initial condition close to the \
bifurcation point.\n\nFlow is slow very close to the fixed point and very \
close to the bifurcation point, so we choose to be close, but not extremely \
close."
}], "Text",
 CellChangeTimes->{{3.8885043420944557`*^9, 3.888504354214511*^9}, {
  3.888504461570718*^9, 3.8885045133511066`*^9}, {3.982853592727899*^9, 
  3.9828535957312717`*^9}, {3.982853785765111*^9, 3.982853883185046*^9}, {
  3.9828539332209873`*^9, 
  3.982853955168672*^9}},ExpressionUUID->"0406147b-0941-46d8-90a3-\
43b40bf281af"],

Cell[CellGroupData[{

Cell["\<\
Explore the behavior of trajectories near the bifurcation and near the fixed \
point\
\>", "Subsubsection",
 CellChangeTimes->{{3.8885043892536993`*^9, 3.8885044476805353`*^9}, 
   3.982853582111228*^9, {3.982854075311775*^9, 
   3.982854089888056*^9}},ExpressionUUID->"16470f1d-2c4f-463c-a191-\
fc67694fd851"],

Cell["\<\
On the side with the stable fixed point (b = bcritical + bstable*bdelta) \
create a backward time trajectory to look for an unstable limit cycle that is \
stabilized in backward time.

On the side with the unstable fixed point (b = bcritical - bstable*bdelta) \
create a forward time trajectory to look for a stable limit cycle that is \
stable in forward time.
\
\>", "Text",
 CellChangeTimes->{{3.8885043420944557`*^9, 3.888504354214511*^9}, {
  3.888504461570718*^9, 3.8885045133511066`*^9}, {3.982853592727899*^9, 
  3.9828535957312717`*^9}, {3.982853785765111*^9, 3.982853883185046*^9}, {
  3.9828539332209873`*^9, 3.982853955168672*^9}, {3.982854677597451*^9, 
  3.9828547661014347`*^9}},ExpressionUUID->"58729059-ff02-4b84-ad19-\
ed5c55a59979"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"forwards", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"backwards", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"-", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bcritical", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bdelta", "=", "0.01"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bstable", "=", 
    RowBox[{"-", "1"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "stable", " ", "is", " ", "below", " ", "bcritical", " ", "is", " ", 
     "use"}], " ", "\[IndentingNewLine]", "-", 
    RowBox[{
    "1", " ", "for", " ", "the", " ", "stable", " ", "direction", " ", "for", 
     " ", "this", " ", "system"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xyIC", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"0.001", ",", "0"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmax", " ", "=", " ", "500"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bbk", "=", 
   RowBox[{"bcritical", "+", 
    RowBox[{"bstable", "*", "bdelta"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"bfwd", "=", 
   RowBox[{"bcritical", "-", 
    RowBox[{"bstable", "*", "bdelta"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solbk", " ", "=", " ", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "'"}], "[", "t", "]"}], ",", 
          RowBox[{
           RowBox[{"y", "'"}], "[", "t", "]"}]}], "}"}], "==", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"backwards", "[", 
           RowBox[{
            RowBox[{"x", "[", "t", "]"}], ",", 
            RowBox[{"y", "[", "t", "]"}]}], "]"}], "/.", 
          RowBox[{"b", "\[Rule]", "bbk"}]}], ")"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", 
        RowBox[{"xyIC", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", 
        RowBox[{"xyIC", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solfwd", "=", " ", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "'"}], "[", "t", "]"}], ",", 
          RowBox[{
           RowBox[{"y", "'"}], "[", "t", "]"}]}], "}"}], "==", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"forwards", "[", 
           RowBox[{
            RowBox[{"x", "[", "t", "]"}], ",", 
            RowBox[{"y", "[", "t", "]"}]}], "]"}], "/.", 
          RowBox[{"b", "\[Rule]", "bfwd"}]}], ")"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", 
        RowBox[{"xyIC", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", 
        RowBox[{"xyIC", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pbck", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], "/.", "solbk"}], ")"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<time\>\"", ",", "\"\<x value\>\""}], "}"}]}], ",", 
     RowBox[{"AxesStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"FontSize", ",", "12"}], "]"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", "\"\<backward time\>\"", "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pfwd", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"(", 
       RowBox[{
