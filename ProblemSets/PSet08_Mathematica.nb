Cell["\<\
We see that forward time saturates to a stable limit cycle, so this is a \
supercritical Hopf (if backward time had saturated to a nearby limit cycle it \
would be a subcritical Hopf)\
\>", "Subsubsection",
 CellChangeTimes->{{3.8885043892536993`*^9, 3.8885044476805353`*^9}, 
   3.982853582111228*^9, {3.982854075311775*^9, 3.982854089888056*^9}, {
   3.982855286054832*^9, 3.982855302852766*^9}, {3.982927077812542*^9, 
   3.982927094750517*^9}},ExpressionUUID->"3954af50-3b78-49ea-a17e-\
96c3c622cdd9"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Create a phase portrait on either side of the bifurcation", "Section",
 CellChangeTimes->{{3.888504106667944*^9, 3.8885041101648073`*^9}, {
  3.888504289144122*^9, 3.888504291723783*^9}, {3.9828553194287558`*^9, 
