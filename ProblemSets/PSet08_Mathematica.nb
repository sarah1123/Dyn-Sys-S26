Cell[CellGroupData[{

Cell["Adjust the line segment to focus on the fixed point", "Subsection",
 CellChangeTimes->{{3.888505601188586*^9, 3.88850560424984*^9}, {
  3.888505675890854*^9, 3.88850569720438*^9}, {3.888582095261327*^9, 
  3.888582097944623*^9}, {3.88858234542038*^9, 
  3.888582375316649*^9}},ExpressionUUID->"51dff703-abef-428b-9d45-\
1254a7c7978c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"y", "+", 
     RowBox[{"\[Mu]", " ", "x"}]}], ",", 
    RowBox[{
     RowBox[{"-", "x"}], "+", 
     RowBox[{"\[Mu]", " ", "y"}], "-", 
     RowBox[{
      RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], "/.", 
    RowBox[{"\[Mu]", "->", "0.01"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fpxval", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"fpyval", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ystop", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"plotlist", "=", 
    RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "the", " ", "table", " ", "of", " ", "values", " ", "for", " ", "the", " ",
     "poincare", " ", "map", " ", "needs", " ", "to", " ", "span", " ", "the",
     " ", "suspected", " ", "limit", " ", 
    RowBox[{"cycle", "."}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"startval", "=", 
   RowBox[{"fpyval", "+", "0.05"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stopval", "=", 
   RowBox[{"fpyval", "+", "0.5"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ystart", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"val", ",", 
      RowBox[{"{", 
       RowBox[{"val", ",", "startval", ",", "stopval", ",", "0.01"}], "}"}]}],
      "]"}]}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "ystart", " ", "is", " ", "a", " ", "list", " ", "of", " ", "initial", 
     " ", "y"}], "-", "values"}], "*)"}]}], "\n", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"ii", "=", "1"}], ",", 
   RowBox[{"ii", "<=", 
    RowBox[{"Length", "[", "ystart", "]"}]}], ",", 
   RowBox[{"ii", "=", 
    RowBox[{"ii", "+", "1"}]}], ",", 
   RowBox[{
    RowBox[{"y0", "=", 
     RowBox[{"ystart", "[", 
      RowBox[{"[", "ii", "]"}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "set", " ", "the", " ", "initial", " ", "y", " ", "value", " ", "with", 
       " ", "the", " ", "ii"}], "-", 
      RowBox[{"th", " ", "element", " ", "of", " ", "ystart"}]}], "*)"}], 
    RowBox[{"solveforward", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], ",", 
             RowBox[{"y", "[", "t", "]"}]}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], ",", 
             RowBox[{"y", "[", "t", "]"}]}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"x", "[", "0", "]"}], "==", "fpxval"}], ",", 
         RowBox[{
          RowBox[{"y", "[", "0", "]"}], "==", "y0"}], ",", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], "==", "fpxval"}], "&&", 
            RowBox[{
             RowBox[{"y", "[", "t", "]"}], ">", "fpyval"}]}], ",", 
           "\"\<StopIntegration\>\""}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "40"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<BDF\>\""}]}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "stop", " ", "the", " ", "integration", " ", "when", " ", "we", " ", 
       "return", " ", "to", " ", "the", " ", "positive", " ", "y"}], "-", 
      "axis"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"solval", "=", 
     RowBox[{"x", "/.", " ", 
      RowBox[{"solveforward", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";", 
    RowBox[{"(*", 
     RowBox[{"pull", " ", "out", " ", "the", " ", "x", 
      RowBox[{"(", "t", ")"}], " ", "solution"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"beginb", ",", "endb"}], "}"}], "=", 
     RowBox[{
      RowBox[{"solval", "[", "\"\<Domain\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "find", " ", "the", " ", "time", " ", "bounds", " ", "associated", " ", 
      "with", " ", "it"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"ystop", ",", 
      RowBox[{
       RowBox[{"y", "[", "endb", "]"}], "/.", " ", 
       RowBox[{"solveforward", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ";"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "evaluate", " ", "y", " ", "at", " ", "the", " ", "stopping", " ", 
    "time"}], "*)"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"p1", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{"x", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "startval", ",", "stopval"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Orange"}], ",", 
     RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<y0\>\"", ",", "\"\<y1\>\""}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", "Medium"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"ystart", ",", "ystop"}], "}"}], "]"}], ",", 
     RowBox[{"PlotMarkers", "->", "Automatic"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Show", "[", 
   RowBox[{"p1", ",", "p2"}], "]"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "This", " ", "is", " ", "so", " ", "close", " ", "to", " ", "the", " ", 
     "y1"}], "=", 
    RowBox[{
     RowBox[{
     "y0", " ", "line", " ", "that", " ", "it", " ", "is", " ", "hard", " ", 
      "to", " ", 
      RowBox[{"tell", "!"}], " ", "So", " ", "plot", " ", "y1"}], "-", 
     RowBox[{"y0", "."}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"ystart", ",", 
      RowBox[{"ystop", "-", "ystart"}]}], "}"}], "]"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<y0\>\"", ",", "\"\<y1-y0\>\""}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "->", "Medium"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.888582388443578*^9, 3.888582392134047*^9}},
 CellLabel->
  "In[579]:=",ExpressionUUID->"18aaf117-f666-4431-8ed7-5b6bed2707a2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"y", "+", 
    RowBox[{"x", " ", "\[Mu]"}]}], ",", 
   RowBox[{
    RowBox[{"-", "x"}], "-", 
    RowBox[{
     SuperscriptBox["x", "2"], " ", "y"}], "+", 
    RowBox[{"y", " ", "\[Mu]"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.888582392807115*^9},
 CellLabel->
  "Out[579]=",ExpressionUUID->"dc28b5af-0cf9-4694-8610-c6b5e4628f5f"],

