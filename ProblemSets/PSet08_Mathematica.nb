Cell["\<\
We see spiraling into the fixed point on the stable side and spiraling into a \
limit cycle on the unstable side.  These were done in forward time and the \
limit cycle is around the unstable fixed point.  This is typical for a \
supercritical Hopf.\
\>", "Subsubsection",
 CellChangeTimes->{{3.8885043892536993`*^9, 3.8885044476805353`*^9}, 
   3.982853582111228*^9, {3.982854075311775*^9, 3.982854089888056*^9}, {
   3.982855286054832*^9, 3.982855302852766*^9}, {3.9828558144881*^9, 
   3.982855838144517*^9}, {3.982856151232172*^9, 3.982856190888639*^9}, {
   3.982927141311502*^9, 
   3.9829271487558947`*^9}},ExpressionUUID->"3780bb0a-9a00-4103-a46c-\
74723a9c0bef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Poincar\[EAcute] map to check for the limit cycle.", "Section",
 CellChangeTimes->{
  3.888505905064747*^9},ExpressionUUID->"ac0e0afd-193d-4fc3-972d-\
94029e8d63a4"],

Cell[CellGroupData[{

Cell["Choose a vertical line segment above the fixed point", "Subsection",
 CellChangeTimes->{{3.888505601188586*^9, 3.88850560424984*^9}, {
  3.888505675890854*^9, 3.88850569720438*^9}, {3.888582095261327*^9, 
  3.888582097944623*^9}, {3.88858234542038*^9, 
  3.888582357856492*^9}},ExpressionUUID->"28b12284-3467-4b52-9ae0-\
fa7c8dff2865"],

Cell["\<\
We start trajectories on a line segment above the fixed point and look for \
when they return to that line segment.

Note: this is a slightly different example system than above, with fixed \
point at (1,0).\
\>", "Text",
 CellChangeTimes->{{3.888505927253248*^9, 3.888506003556518*^9}, {
  3.888506133399675*^9, 3.8885061449955387`*^9}, {3.9828562421446247`*^9, 
  3.982856244469109*^9}, {3.982856291029798*^9, 3.982856315569015*^9}, {
  3.9829271569262466`*^9, 3.982927187576899*^9}, {3.9829272345661716`*^9, 
  3.9829272353428907`*^9}},ExpressionUUID->"d661a47c-bc49-48e3-a95b-\
52d1ba4792f1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"y", "+", 
     RowBox[{"m", "*", 
      RowBox[{"(", 
       RowBox[{"x", "-", "1"}], ")"}]}]}], ",", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"x", "-", "1"}], ")"}]}], "+", 
     RowBox[{"m", "*", "y"}], "-", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "-", "1"}], ")"}], "^", "2"}], "*", "y"}]}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], "/.", 
     RowBox[{"m", "->", "0.01"}]}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"m", " ", "=", " ", 
    RowBox[{
    "0.01", " ", "is", " ", "a", " ", "parameter", " ", "value", " ", "with", 
     " ", "a", " ", "limit", " ", "cycle"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fixedpointlocation", "=", 
    RowBox[{"{", 
     RowBox[{"1", ",", "0"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"set", " ", "the", " ", "fixed", " ", "point"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"maxtime", " ", "=", " ", "50"}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "integration", " ", "needs", " ", "to", " ", "be", " ", "long", " ", 
    "enough", " ", "to", " ", "return", " ", "to", " ", "the", " ", "line", 
    " ", "segment"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ymin", " ", "=", " ", "0.05"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ymax", " ", "=", " ", "0.5"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "radius", " ", "of", " ", "the", " ", "limit", " ", "cycle", 
    " ", "needs", " ", "to", " ", "be", " ", "between", " ", "ymin", " ", 
    "and", " ", "ymax", " ", "for", " ", "us", " ", "to", " ", "see", " ", 
    "it"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ystep", " ", "=", " ", "0.01"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ystop", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"plotlist", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"startval", "=", 
   RowBox[{
    RowBox[{"fixedpointlocation", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "+", "ymin"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stopval", "=", 
   RowBox[{
    RowBox[{"fixedpointlocation", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "+", "ymax"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ystart", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"val", ",", 
      RowBox[{"{", 
       RowBox[{"val", ",", "startval", ",", "stopval", ",", "ystep"}], 
       "}"}]}], "]"}]}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "ystart", " ", "is", " ", "a", " ", "list", " ", "of", " ", "initial", 
     " ", "y"}], "-", "values"}], "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"ii", "=", "1"}], ",", 
    RowBox[{"ii", "<=", 
     RowBox[{"Length", "[", "ystart", "]"}]}], ",", 
    RowBox[{"ii", "=", 
     RowBox[{"ii", "+", "1"}]}], ",", 
    RowBox[{
     RowBox[{"y0", "=", 
      RowBox[{"ystart", "[", 
       RowBox[{"[", "ii", "]"}], "]"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "set", " ", "the", " ", "initial", " ", "y", " ", "value", " ", "with",
         " ", "the", " ", "ii"}], "-", 
       RowBox[{"th", " ", "element", " ", "of", " ", "ystart"}]}], "*)"}], 
     RowBox[{"solveforward", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
           RowBox[{
            RowBox[{"g", "[", 
             RowBox[{
              RowBox[{"x", "[", "t", "]"}], ",", 
              RowBox[{"y", "[", "t", "]"}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
           RowBox[{
            RowBox[{"g", "[", 
             RowBox[{
              RowBox[{"x", "[", "t", "]"}], ",", 
              RowBox[{"y", "[", "t", "]"}]}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"x", "[", "0", "]"}], "==", 
           RowBox[{"fixedpointlocation", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"y", "[", "0", "]"}], "==", "y0"}], ",", 
          RowBox[{"WhenEvent", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"x", "[", "t", "]"}], "==", 
              RowBox[{"fixedpointlocation", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "&&", 
             RowBox[{
              RowBox[{"y", "[", "t", "]"}], ">", 
              RowBox[{"fixedpointlocation", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
            "\"\<StopIntegration\>\""}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "maxtime"}], "}"}], ",", 
        RowBox[{"Method", "->", "\"\<BDF\>\""}]}], "]"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "stop", " ", "the", " ", "integration", " ", "when", " ", "we", " ", 
        "return", " ", "to", " ", "the", " ", "positive", " ", "y"}], "-", 
       "axis"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"solval", "=", 
      RowBox[{"x", "/.", " ", 
       RowBox[{"solveforward", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", 
     RowBox[{"(*", 
      RowBox[{"pull", " ", "out", " ", "the", " ", "x", 
       RowBox[{"(", "t", ")"}], " ", "solution"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"beginb", ",", "endb"}], "}"}], "=", 
      RowBox[{
       RowBox[{"solval", "[", "\"\<Domain\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
      "find", " ", "the", " ", "time", " ", "bounds", " ", "associated", " ", 
       "with", " ", "it"}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"ystop", ",", 
       RowBox[{
        RowBox[{"y", "[", "endb", "]"}], "/.", " ", 
        RowBox[{"solveforward", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ";"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "evaluate", " ", "y", " ", "at", " ", "the", " ", "stopping", " ", 
     "time"}], "*)"}], "]"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"p1", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{"x", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "stopval"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Orange"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"ystart", ",", "ystop"}], "}"}], "]"}], ",", 
     RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<y0\>\"", ",", "\"\<y1\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Poincar\[EAcute] map\>\""}], ",", 
     RowBox[{"AspectRatio", "->", "1"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"poincare", " ", "=", " ", 
    RowBox[{"Show", "[", 
     RowBox[{"p2", ",", "p1", ",", 
      RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y0y1diff", " ", "=", " ", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"ystart", ",", 
        RowBox[{"ystop", "-", "ystart"}]}], "}"}], "]"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<y0\>\"", ",", "\"\<y1-y0\>\""}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", "Medium"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p0", " ", "=", " ", 
   RowBox[{"Plot", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "0.5"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Orange"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"diffmap", " ", "=", " ", 
    RowBox[{"Show", "[", 
     RowBox[{"y0y1diff", ",", "p0", ",", 
      RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"GraphicsGrid", "[", 
  RowBox[{"{", 
   RowBox[{"{", 
    RowBox[{"poincare", ",", "diffmap"}], "}"}], "}"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "The", " ", "Poincare", " ", "map", " ", "data", " ", "is", " ", "so", 
     " ", "close", " ", "to", " ", "the", " ", "y1"}], " ", "=", 
    RowBox[{
     RowBox[{
     "y0", " ", "line", " ", "that", " ", "it", " ", "is", " ", "hard", " ", 
      "to", " ", 
      RowBox[{"tell", "!"}], " ", "So", " ", "plot", " ", "y1"}], "-", 
     RowBox[{"y0", "."}]}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982856228756303*^9, 3.982856233899858*^9}, {
  3.982927170198968*^9, 3.9829271813988323`*^9}, {3.982927223264058*^9, 
  3.982927771927544*^9}},ExpressionUUID->"30a19292-2dd8-4681-aa83-\
7bfae8dc8ee6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"m", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "x"}], ")"}]}], "+", "y"}], ",", 
   RowBox[{"1", "-", "x", "+", 
    RowBox[{"m", " ", "y"}], "-", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "x"}], ")"}], "2"], " ", "y"}]}]}], 
  "}"}]], "Output",
