  3.98285526824588*^9}},ExpressionUUID->"432b6f44-8055-40a1-9f00-\
85dc4b6251b7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tmax2", " ", "=", " ", "800"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solbk2", " ", "=", " ", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "'"}], "[", "t", "]"}], ",", 
          RowBox[{
           RowBox[{"y", "'"}], "[", "t", "]"}]}], "}"}], "==", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"backwards", "[", 
           RowBox[{
            RowBox[{"x", "[", "t", "]"}], ",", 
            RowBox[{"y", "[", "t", "]"}]}], "]"}], "/.", 
          RowBox[{"b", "\[Rule]", "bbk"}]}], ")"}]}], ",", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "==", 
        RowBox[{"xyIC", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", 
        RowBox[{"xyIC", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"solfwd2", "=", " ", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], "[", "t", "]"}], ",", 
           RowBox[{
            RowBox[{"y", "'"}], "[", "t", "]"}]}], "}"}], "==", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"forwards", "[", 
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], ",", 
             RowBox[{"y", "[", "t", "]"}]}], "]"}], "/.", 
           RowBox[{"b", "\[Rule]", "bfwd"}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"x", "[", "0", "]"}], "==", 
         RowBox[{"xyIC", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", 
         RowBox[{"xyIC", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "tmax2"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "we", " ", "run", " ", "into", " ", "an", " ", "integration", " ", "error",
     " ", "because", " ", "one", " ", "of", " ", "the", " ", "trajectories", 
    " ", "is", " ", "diverging", " ", "to", " ", "infinity"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"tmaxActualbk", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "/.", 
      RowBox[{"solbk2", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "[", "\"\<Domain\>\"", "]"}], 
   "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pbck2", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"(", 
