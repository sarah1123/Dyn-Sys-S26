     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<time\>\"", ",", "\"\<x value\>\""}], "}"}]}], ",", 
     RowBox[{"AxesStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"FontSize", ",", "12"}], "]"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
