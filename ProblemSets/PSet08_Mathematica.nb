Notebook[{
Cell["Problem Set 08", "Section",
 CellChangeTimes->{{3.8885040930208893`*^9, 
  3.888504094998166*^9}},ExpressionUUID->"1757a628-8a1b-43df-bd10-\
3343f474a87d"],

Cell[CellGroupData[{

Cell["Check for local bifurcations", "Section",
 CellChangeTimes->{{3.888504106667944*^9, 3.8885041101648073`*^9}, {
  3.888504289144122*^9, 
  3.888504291723783*^9}},ExpressionUUID->"d7ea5ba7-faf7-4afc-bb1d-\
d63db8859c46"],

Cell[CellGroupData[{

Cell["\<\
Check for saddle-node, transcritical, or pitchfork bifurcations (look at the \
determinant)\
\>", "Subsection",ExpressionUUID->"afa41cb1-af36-44e9-bbc6-c59f5cff9f61"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], " ", "=", 
  RowBox[{"{", " ", 
   RowBox[{
    RowBox[{"y", " ", "+", " ", 
     RowBox[{"b", " ", "x"}]}], ",", " ", 
    RowBox[{
     RowBox[{"-", "x"}], " ", "+", " ", 
     RowBox[{"b", " ", "y"}], " ", "-", " ", 
     RowBox[{
      RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "}"}]}], "\n", 
 RowBox[{"fp", " ", "=", " ", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], "==", "0"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"jacobian", " ", "=", " ", 
   RowBox[{"Grad", "[", 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tracevals", " ", "=", " ", 
   RowBox[{
    RowBox[{"Tr", "[", "jacobian", "]"}], "/.", "fp"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"detvals", " ", "=", " ", 
   RowBox[{
    RowBox[{"Det", "[", "jacobian", "]"}], "/.", "fp"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"detvals", "[", 
        RowBox[{"[", "k", "]"}], "]"}], "==", "0"}], ",", "\[Mu]"}], "]"}], 
    ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Use", " ", "\"\<Table\>\"", " ", "to", " ", "process", " ", "each", " ", 
    "fixed", " ", "point", " ", 
    RowBox[{"separately", "."}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "None", " ", "of", " ", "the", " ", "fixed", " ", "points", " ", "in", 
     " ", "this", " ", "system", " ", "have", " ", "Determinant", " ", "zero",
      " ", "at", " ", "any", " ", "real", " ", "parameter", " ", "value"}], 
    ",", " ", 
    RowBox[{
     RowBox[{"so", " ", "no", " ", "saddle"}], "-", 
     RowBox[{
      RowBox[{"node", "/", "transcritical"}], "/", 
      RowBox[{"pitchfork", "."}]}]}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.888504161931437*^9, 3.888504170689404*^9}, {
  3.982854007720655*^9, 3.982854009971298*^9}},
 CellLabel->
  "In[377]:=",ExpressionUUID->"a7fc4c77-664a-4df9-93b2-cc7e62483ba4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"b", " ", "x"}], "+", "y"}], ",", 
   RowBox[{
    RowBox[{"-", "x"}], "+", 
    RowBox[{"b", " ", "y"}], "-", 
    RowBox[{
     SuperscriptBox["x", "2"], " ", "y"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.8885041583532124`*^9, 3.888582188117546*^9, 
  3.982853542299189*^9, 3.9828540105029097`*^9},
 CellLabel->
  "Out[377]=",ExpressionUUID->"d9a7d66b-9314-47c7-a0b1-833bb326f5a9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "0"}], ",", 
     RowBox[{"y", "\[Rule]", "0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", 
      RowBox[{"-", 
       FractionBox[
        SqrtBox[
         RowBox[{"1", "+", 
          SuperscriptBox["b", "2"]}]], 
        SqrtBox["b"]]}]}], ",", 
     RowBox[{"y", "\[Rule]", 
      RowBox[{
       SqrtBox["b"], " ", 
       SqrtBox[
        RowBox[{"1", "+", 
         SuperscriptBox["b", "2"]}]]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", 
      FractionBox[
       SqrtBox[
        RowBox[{"1", "+", 
         SuperscriptBox["b", "2"]}]], 
       SqrtBox["b"]]}], ",", 
     RowBox[{"y", "\[Rule]", 
      RowBox[{
       RowBox[{"-", 
        SqrtBox["b"]}], " ", 
       SqrtBox[
        RowBox[{"1", "+", 
         SuperscriptBox["b", "2"]}]]}]}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.8885041583532124`*^9, 3.888582188117546*^9, 
  3.982853542299189*^9, 3.9828540105056353`*^9},
 CellLabel->
  "Out[378]=",ExpressionUUID->"eea8ab9d-f93a-46bd-9478-d1417c00eaad"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", "}"}], ",", 
   RowBox[{"{", "}"}], ",", 
   RowBox[{"{", "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.8885041583532124`*^9, 3.888582188117546*^9, 
  3.982853542299189*^9, 3.982854010508315*^9},
 CellLabel->
  "Out[382]=",ExpressionUUID->"258d1cd2-1311-43a7-b54a-c9410b36bf0b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Check for Hopf bifurcations (look at the trace and determinant)\
\>", "Subsection",ExpressionUUID->"d6ff540b-ec80-4c9e-8007-ae2327840cdf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"possiblehopf", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"tracevals", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "==", "0"}], ",", "b"}], "]"}], ",", 
     
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}]}], " ", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Use", " ", "\"\<Table\>\"", " ", "to", " ", "process", " ", "each", " ", 
    "fixed", " ", "point", " ", 
    RowBox[{"separately", "."}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Each", " ", "of", " ", "the", " ", "fixed", " ", "points", " ", "has", 
     " ", "trace"}], " ", "=", " ", 
    RowBox[{
    "0", " ", "for", " ", "at", " ", "least", " ", "one", " ", "parameter", 
     " ", 
     RowBox[{"value", "."}]}]}], "*)"}]}], "\n", 
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"detvals", "[", 
     RowBox[{"[", "k", "]"}], "]"}], "/.", 
    RowBox[{"possiblehopf", "[", 
     RowBox[{"[", "k", "]"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Check", " ", "the", " ", "value", " ", "of", " ", "the", " ", 
    "determinant", " ", "for", " ", "each", " ", "fixed", " ", "point", " ", 
    "at", " ", "the", " ", "parameter", " ", "values", " ", "where", " ", 
    "the", " ", "trace", " ", "is", " ", "zero"}], " ", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982854017081091*^9, 3.9828540171828003`*^9}},
 CellLabel->
  "In[385]:=",ExpressionUUID->"ce7d4920-ae38-4c5b-b862-1d0b55f1b690"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"b", "\[Rule]", "0"}], "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"b", "\[Rule]", 
       RowBox[{"-", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", "\[Rule]", "1"}], "}"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"b", "\[Rule]", 
       RowBox[{"-", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", "\[Rule]", "1"}], "}"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.888504188803296*^9, 3.888582190252419*^9, 3.982853544945835*^9, {
   3.98285401313281*^9, 3.982854017500477*^9}},
 CellLabel->
  "Out[385]=",ExpressionUUID->"cc65eac4-6eb1-4f18-9ffb-589e10560001"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", "1", "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "4"}], ",", 
     RowBox[{"-", "4"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "4"}], ",", 
     RowBox[{"-", "4"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.888504188803296*^9, 3.888582190252419*^9, 3.982853544945835*^9, {
   3.98285401313281*^9, 3.982854017502802*^9}},
 CellLabel->
  "Out[386]=",ExpressionUUID->"9d64519f-badf-4b35-a204-a80a2d569972"]
